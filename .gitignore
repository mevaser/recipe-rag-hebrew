# =========================
# Python cache
# =========================
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# =========================
# Virtual environments
# =========================
.venv/
venv/
env/

# =========================
# Secrets / environment files
# =========================
.env
.env.*
!.env.example

# =========================
# Logs
# =========================
*.log

